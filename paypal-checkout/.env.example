# PayPal Checkout Configuration
# Copy this file to .env and fill in your actual credentials
# NEVER commit .env to version control

# PayPal API Base URL
# Sandbox: https://api.sandbox.paypal.com
# Live: https://api.paypal.com
PAYPAL_API_BASE=https://api.sandbox.paypal.com

# PayPal API Credentials
# Get these from: https://developer.paypal.com/dashboard/applications
PAYPAL_CLIENT_ID=your_client_id_here
PAYPAL_SECRET=your_secret_here

# Return URLs (optional - defaults to auto-detect)
# These are used for redirect after payment approval/cancellation
PAYPAL_RETURN_URL=
PAYPAL_CANCEL_URL=

# Webhook ID (optional - only if using webhooks)
# Get this from: https://developer.paypal.com/dashboard/webhooks
PAYPAL_WEBHOOK_ID=

# Tap Payments (optional - for Cards, Mada)
# Get from: https://tap.company/developers
TAP_SECRET_KEY=your_tap_secret_key
