// Apply mixins from feature files (professional.utilities.js, etc.)
(function() {
    const queue = window.__professionalAccountingAttachQueue;
    if (queue && Array.isArray(queue)) {
        queue.forEach(function(m) {
            Object.assign(ProfessionalAccounting.prototype, m);
        });
        window.__professionalAccountingAttachQueue = [];
    }
})();
// Initialize when DOM is loaded
document.addEventListener('DOMContentLoaded', () => {
    if (!window.professionalAccounting) {
        window.professionalAccounting = new ProfessionalAccounting();
    }
});
// Also initialize immediately if DOM is already loaded (for cases where script loads after DOMContentLoaded)
if (document.readyState === 'loading') {
    // DOM is still loading, wait for DOMContentLoaded (handled above)
            } else {
    // DOM is already loaded, initialize immediately
    if (!window.professionalAccounting) {
        window.professionalAccounting = new ProfessionalAccounting();
    }
}