                                'Delete Customer',
                                'Are you sure you want to delete this customer?',
                                'Delete',
                                'Cancel',
                                'danger'
                            );
                            if (confirmed) {
                        this.deleteCustomer(delCustomerId);
                            }
                        })();
                    }
                    break;
