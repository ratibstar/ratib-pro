                    if (deleteBankTransId) {
                        this.deleteBankTransaction(deleteBankTransId);
                    }
                    break;
                case 'manage-customers':
                    this.openCustomersModal();
                    break;
                case 'manage-vendors':
                    this.openVendorsModal();
                    break;
                case 'manage-periods':
                    this.openPeriodsModal();
                    break;
                case 'manage-tax':
                    this.openTaxSettingsModal();
                    break;
                case 'new-customer':
