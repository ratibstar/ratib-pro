            formHTML = await this.getEntityTransactionFormHTML(null);
        }
        
        // If formHTML is empty (error occurred), use new transaction form
        if (!formHTML) {
            formHTML = await this.getEntityTransactionFormHTML(null);
        }
        
        const modalContent = `
            <div class="accounting-tabs">
                <button class="tab-btn active" data-tab="transactions">
