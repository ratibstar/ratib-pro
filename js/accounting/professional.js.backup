                            </div>
                            <div class="filter-group filter-group-compact">
                                <label>Date To:</label>
                                <input type="text" id="modalArDateTo" class="filter-input filter-input-compact date-input" value="${this.modalArDateTo}" placeholder="MM/DD/YYYY">
                            </div>
                            <div class="filter-group filter-group-compact">
