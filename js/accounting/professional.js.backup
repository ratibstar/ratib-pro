                this.bankGuaranteeCurrentPage = 1;
                this.loadBankGuarantees();
            });
        }

        // Pagination handlers
        const prevBtn = document.getElementById('bankGuaranteePrevBtn');
        const nextBtn = document.getElementById('bankGuaranteeNextBtn');
        
        if (prevBtn) {
