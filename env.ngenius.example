# Copy to .env in the same folder as api/ and config/ (e.g. public_html/.env on cPanel).
# Saudi (KSA) LIVE settings only. See config/env/out_ratib_sa.php.
#
# KSA live:
# NGENIUS_TOKEN_URL=https://api-gateway.ksa.ngenius-payments.com/identity/auth/access-token
# NGENIUS_REALM=networkinternational
#
# NGENIUS_API_KEY = paste the full string NI shows for Basic auth (often one base64 line). Leave NGENIUS_API_SECRET empty unless NI gives two fields.

NGENIUS_OUTLET_ID=
NGENIUS_API_KEY=
NGENIUS_API_SECRET=

# Checkout currency for the outlet (KSA portals usually settle in SAR).
# Site prices are in USD; when NGENIUS_CHECKOUT_CURRENCY=SAR, the API converts USD→SAR
# before sending minor units (halalas) to N-Genius. Peg default 3.75; override if needed.
NGENIUS_CHECKOUT_CURRENCY=SAR
NGENIUS_USD_TO_SAR=3.75
